<?xml version="1.0" encoding="utf-8"?>
<resources>

<style name="Theme.DrugDose" parent="Theme.MaterialComponents.NoActionBar" >

    <!--Colori principali-->
    <item name="colorPrimary">@color/accent_primary</item>
    <item name="colorPrimaryVariant">@color/accent_secondary</item>
    <item name="colorOnPrimary">@color/white</item>
    <item name="colorSecondary">@color/accent_pink</item>
    <item name="colorOnSecondary">@color/white</item>

    <!--Background-->
    <item name="android:windowBackground">@color/bg_light</item>
    <item name="android:colorBackground">@color/bg_light</item>
    <item name="colorSurface">@color/bg_card</item>
    <item name="colorOnSurface">@color/text_primary</item>

   <!--Testo-->
    <item name="android:textColorPrimary">@color/text_primary</item>
    <item name="android:textColorSecondary">@color/text_secondary</item>
    <item name="android:textColorHint">@color/text_hint</item>

    <!--  Status bar  -->
    <item name="android:statusBarColor">@color/bg_light</item>
    <item name="android:windowLightStatusBar">true</item>

    <!--  Input fields  -->
    <item name="colorControlNormal">@color/text_hint</item>
    <item name="colorControlActivated">@color/accent_primary</item>
    <item name="colorControlHighlight">@color/accent_glow</item>

    </style>


    <!--  Stile per TextInputLayout  -->
    <style name="DrugDose.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/selector_input_stroke</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="hintTextColor">@color/accent_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>


    <!--  Stile per il Button principale  -->
    <style name="DrugDose.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="elevation">4dp</item>
    </style>


    <!-- Bottone secondario outline -->
    <style name="DrugDose.Button.Outline"
        parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_primary</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <!-- Stile Result Activity -->
    <style name="DrugDose.ResultActivity"
        parent="Theme.DrugDose">
        <item name="android:windowBackground">@color/bg_light</item>
    </style>

</resources>